## FHIR server
APPLICATION_NAME=fhir-server
SERVER_ADDRESS=0.0.0.0
REQUEST_VALIDATION=false
RESPONSE_VALIDATION=false
SQL_DIALECT=ca.uhn.fhir.jpa.model.dialect.HapiFhirPostgres94Dialect
SQL_DRIVER=org.postgresql.Driver
# SQL_URL=jdbc:postgresql://clinomic-fhir-postgres:5432/hapi
SQL_USERNAME=admin
SQL_PASSWORD=admin
OPENSEARCH_ENABLED=false
OPENSEARCH_URL=localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin
SUBSCRIPTION_REST_ENABLED=false
SUBSCRIPTION_EMAIL_ENABLED=false
SUBSCRIPTION_WEBSOCKET_ENABLED=false
AUDIT_EVENT=true
LOG_REQUEST_BODY=false
LOG_APPENDER_TYPE=JSON
logging.config=file:./src/main/resources/logback.xml
#SPRING_PROFILES_ACTIVE=dev
JAVA_OPTS=-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005

## Docker registry
DOCKER_REGISTRY=www.clinomic.biz:5050/mona